rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================================
    // FUNÇÕES AUXILIARES DE VALIDAÇÃO
    // ==========================================================
    
    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Atualizado para reconhecer o seu perfil
    function isSuperAdmin() {
      return isAuth() && getUserData().role == 'super_admin';
    }

    // Reconhece os gestores das academias cadastradas
    function isGymAdmin() {
      return isAuth() && getUserData().role == 'gym_admin';
    }

    // ==========================================================
    // REGRAS POR COLEÇÃO
    // ==========================================================

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin() || (isAuth() && request.auth.uid == userId);
    }

    match /workout_templates/{templateId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    match /academias/{academiaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isSuperAdmin() || isGymAdmin();
    }

    match /beta_feedback/{feedbackId} {
      allow create: if isAuth();
      allow read, update, delete: if isSuperAdmin();
    }
  }
}